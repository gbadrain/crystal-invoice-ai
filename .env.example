# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, local, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# Optional: non-pooled direct URL (needed for Prisma migrations on Neon)
DATABASE_URL_NEON_DIRECT=postgresql://user:password@host:5432/dbname

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
# Must match your deployment URL exactly (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ─── Anthropic (AI invoice generation) ───────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ─── Stripe (billing / subscriptions) ────────────────────────────────────────
# https://dashboard.stripe.com → Developers → API Keys
# 1. Create a Product "Crystal Invoice Pro" with a recurring price of $9/month
# 2. Copy the Price ID (starts with price_)
# 3. For local webhook testing: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_SECRET_KEY=your-stripe-secret-key-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret-here
STRIPE_PRO_PRICE_ID=your-stripe-price-id-here

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# https://resend.com — free tier: 3000 emails/month
# Add a verified sending domain, or use onboarding@resend.dev for testing only
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM=Crystal Invoice AI <noreply@yourdomain.com>

# ─── Express Server (PDF + AI) ────────────────────────────────────────────────
EXPRESS_PORT=3001
# In production, set this to your Railway deployment URL:
NEXT_PUBLIC_EXPRESS_URL=https://your-express-server.railway.app

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
